# NoCodeBackend — file storage
NCB_INSTANCE=36905_visualessential
NCB_API_URL=https://openapi.nocodebackend.com
NCB_SECRET_KEY=your-secret-key

# xAI — scene image + video generation
# Token file is written by: cd xai-oauth-client && python -m xai_oauth login
# Default path is ~/.xai-oauth/tokens.json — only set this if you moved it.
# XAI_TOKEN_PATH=/Users/you/.xai-oauth/tokens.json
